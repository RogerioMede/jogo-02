int dentroMapa(int l, int c) {
    if (l >= 0 && l < linhas && c >= 0 && c < colunas) {
        return 1;
    }
    return 0;
}


int podeMonstroAndar(int l, int c) {
    if (dentroMapa(l, c) == 0) {
        return 0;
    }

    if (mapa[l][c] == ' ') {
        return 1;
    }

    return 0;
}


int podeBossAndar(int l, int c) {
    if (dentroMapa(l, c) == 0) {
        return 0;
    }

    if (mapa[l][c] == ' ') {
        return 1;
    }

    return 0;
}


int absoluto(int n) {
    if (n < 0) {
        return -n;
    }
    return n;
}


char nomeArma() {
    if (arma == 1) return 'E';
    if (arma == 2) return 'A';
    if (arma == 3) return 'C';
    return '-';
}

