void jogar() {
    vidas = 3;
    arma = 0;
    chaves = 0;
    faseAtual = 0;
    voltarMenu = 0;
    mudouFase = 0;
    perdeuNoTurno = 0;

    iniciarVila();
    strcpy(mensagem, "Fale com o NPC (N) usando i para escolher sua arma.");

    while (voltarMenu == 0) {
        char comando;

        mostrarMapa();
        printf("Comando: ");
        comando = lerTecla();
        printf("%c\n", comando);

        mudouFase = 0;
        perdeuNoTurno = 0;
        strcpy(mensagem, "");

        if (comando == 'q' || comando == 'Q') {
            voltarMenu = 1;
        } else {
            processarComando(comando);

            if (voltarMenu == 0 && mudouFase == 0 && perdeuNoTurno == 0) {
                if (faseAtual == 2 || faseAtual == 3) {
                    moverMonstros();
                }
            }
        }
    }
}


void preencherMapa(int l, int c) {
    int i, j;

    linhas = l;
    colunas = c;

    for (i = 0; i < MAX; i++) {
        for (j = 0; j < MAX; j++) {
            mapa[i][j] = ' ';
        }
        mapa[i][MAX] = '\0';
    }
}


void criarBordas() {
    int i, j;

    for (i = 0; i < linhas; i++) {
        for (j = 0; j < colunas; j++) {
            if (i == 0 || i == linhas - 1 || j == 0 || j == colunas - 1) {
                mapa[i][j] = '*';
            }
        }
    }
}


