void processarComando(char comando) {
    if (comando == 'w' || comando == 'W') {
        tentarMover(-1, 0, '^');
    } else if (comando == 'a' || comando == 'A') {
        tentarMover(0, -1, '<');
    } else if (comando == 's' || comando == 'S') {
        tentarMover(1, 0, 'v');
    } else if (comando == 'd' || comando == 'D') {
        tentarMover(0, 1, '>');
    } else if (comando == 'i' || comando == 'I') {
        interagir();
    } else if (comando == 'o' || comando == 'O') {
        atacar();
    } else {
        strcpy(mensagem, "Comando invalido.");
    }
}


void tentarMover(int dl, int dc, char novaDirecao) {
    int nl, nc;
    char alvo;

    direcao = novaDirecao;
    nl = jogadorL + dl;
    nc = jogadorC + dc;

    if (dentroMapa(nl, nc) == 0) {
        strcpy(mensagem, "Voce nao pode sair do mapa.");
        return;
    }

    alvo = mapa[nl][nc];

    if (alvo == '*' || alvo == 'k' || alvo == 'D' || alvo == 'N') {
        strcpy(mensagem, "Caminho bloqueado. Use i para interagir ou o para atacar.");
        return;
    }

    if (alvo == '#') {
        receberDano("Voce pisou em um espinho.");
        return;
    }

    if (alvo == 'X' || alvo == 'Y' || alvo == 'Z') {
        receberDano("Voce encostou em um monstro.");
        return;
    }

    if (alvo == '@') {
        chaves++;
        mapa[nl][nc] = ' ';
        strcpy(mensagem, "Voce pegou uma chave.");
    }

    if (alvo == 'L') {
        if (faseAtual == 0) {
            if (arma == 0) {
                strcpy(mensagem, "Escolha uma arma com o NPC antes de entrar.");
                return;
            } else {
                iniciarAndar1();
                mudouFase = 1;
                return;
            }
        } else if (faseAtual == 1) {
            iniciarAndar2();
            mudouFase = 1;
            return;
        } else if (faseAtual == 2) {
            iniciarAndar3();
            mudouFase = 1;
            return;
        }
    }

    jogadorL = nl;
    jogadorC = nc;
}


void interagir() {
    int al, ac;
    char alvo;

    al = jogadorL;
    ac = jogadorC;

    if (direcao == '^') {
        al--;
    } else if (direcao == 'v') {
        al++;
    } else if (direcao == '<') {
        ac--;
    } else if (direcao == '>') {
        ac++;
    }

    if (dentroMapa(al, ac) == 0) {
        strcpy(mensagem, "Nao ha nada para interagir.");
        return;
    }

    alvo = mapa[al][ac];

    if (alvo == 'N') {
        escolherArma();
    } else if (alvo == '@') {
        chaves++;
        mapa[al][ac] = ' ';
        strcpy(mensagem, "Voce pegou uma chave.");
    } else if (alvo == 'D') {
        if (chaves > 0) {
            chaves--;
            mapa[al][ac] = '=';
            strcpy(mensagem, "Voce abriu uma porta.");
        } else {
            strcpy(mensagem, "A porta esta trancada. Voce precisa de uma chave.");
        }
    } else if (alvo == 'O') {
        ativarBotao();
    } else if (alvo == 'L') {
        strcpy(mensagem, "Ande para cima da escada para avancar.");
    } else {
        strcpy(mensagem, "Nao ha nada importante para interagir aqui.");
    }
}


