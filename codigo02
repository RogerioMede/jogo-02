void atacar() {
    int i, j;

    if (arma == 0) {
        strcpy(mensagem, "Voce ainda nao escolheu uma arma.");
        return;
    }

    strcpy(mensagem, "Voce atacou, mas nao acertou nada.");

    if (arma == 1) {
        /* Espada: area 3 x 2 na direcao do jogador */
        if (direcao == '^') {
            for (i = 1; i <= 2; i++) {
                for (j = -1; j <= 1; j++) {
                    atacarCelula(jogadorL - i, jogadorC + j);
                }
            }
        } else if (direcao == 'v') {
            for (i = 1; i <= 2; i++) {
                for (j = -1; j <= 1; j++) {
                    atacarCelula(jogadorL + i, jogadorC + j);
                }
            }
        } else if (direcao == '<') {
            for (i = 1; i <= 2; i++) {
                for (j = -1; j <= 1; j++) {
                    atacarCelula(jogadorL + j, jogadorC - i);
                }
            }
        } else if (direcao == '>') {
            for (i = 1; i <= 2; i++) {
                for (j = -1; j <= 1; j++) {
                    atacarCelula(jogadorL + j, jogadorC + i);
                }
            }
        }
    } else if (arma == 2) {
        /* Arco: 4 casas em linha reta */
        for (i = 1; i <= 4; i++) {
            if (direcao == '^') {
                atacarCelula(jogadorL - i, jogadorC);
            } else if (direcao == 'v') {
                atacarCelula(jogadorL + i, jogadorC);
            } else if (direcao == '<') {
                atacarCelula(jogadorL, jogadorC - i);
            } else if (direcao == '>') {
                atacarCelula(jogadorL, jogadorC + i);
            }
        }
    } else if (arma == 3) {
        /* Cajado: 8 casas ao redor */
        for (i = -1; i <= 1; i++) {
            for (j = -1; j <= 1; j++) {
                if (!(i == 0 && j == 0)) {
                    atacarCelula(jogadorL + i, jogadorC + j);
                }
            }
        }
    }
}


void atacarCelula(int l, int c) {
    if (dentroMapa(l, c) == 0) {
        return;
    }

    if (mapa[l][c] == 'k') {
        mapa[l][c] = ' ';
        strcpy(mensagem, "Voce destruiu uma caixa.");
    } else if (mapa[l][c] == 'X' || mapa[l][c] == 'Y') {
        mapa[l][c] = ' ';
        strcpy(mensagem, "Voce derrotou um monstro.");
    } else if (mapa[l][c] == 'Z') {
        bossVida--;
        if (bossVida <= 0) {
            mapa[l][c] = ' ';
            telaVitoria();
            voltarMenu = 1;
        } else {
            sprintf(mensagem, "Voce acertou o boss! Vida restante do boss: %d.", bossVida);
        }
    }
}


void moverMonstros() {
    int ml[MAX_MONSTROS], mc[MAX_MONSTROS], tipo[MAX_MONSTROS];
    int total;
    int i, j;

    total = 0;

    for (i = 0; i < linhas; i++) {
        for (j = 0; j < colunas; j++) {
            if ((mapa[i][j] == 'X' || mapa[i][j] == 'Y') && total < MAX_MONSTROS) {
                ml[total] = i;
                mc[total] = j;
                if (mapa[i][j] == 'X') {
                    tipo[total] = 1;
                } else {
                    tipo[total] = 2;
                }
                total++;
            }
        }
    }

    for (i = 0; i < total; i++) {
        int dl, dc, novaL, novaC, dir;
        char simbolo;

        if (perdeuNoTurno == 1 || voltarMenu == 1) {
            return;
        }

        if (tipo[i] == 1) {
            simbolo = 'X';
        } else {
            simbolo = 'Y';
        }

        if (dentroMapa(ml[i], mc[i]) == 0) {
            continue;
        }

        if (mapa[ml[i]][mc[i]] != simbolo) {
            continue;
        }

        dl = 0;
        dc = 0;

        if (tipo[i] == 1) {
            dir = rand() % 4;
            if (dir == 0) dl = -1;
            if (dir == 1) dl = 1;
            if (dir == 2) dc = -1;
            if (dir == 3) dc = 1;
        } else {
            if (absoluto(jogadorL - ml[i]) > absoluto(jogadorC - mc[i])) {
                if (jogadorL < ml[i]) dl = -1;
                if (jogadorL > ml[i]) dl = 1;
            } else {
                if (jogadorC < mc[i]) dc = -1;
                if (jogadorC > mc[i]) dc = 1;
            }
        }

        novaL = ml[i] + dl;
        novaC = mc[i] + dc;

        if (novaL == jogadorL && novaC == jogadorC) {
            receberDano("Um monstro tocou em voce.");
            return;
        }

        if (podeMonstroAndar(novaL, novaC) == 1) {
            mapa[ml[i]][mc[i]] = ' ';
            mapa[novaL][novaC] = simbolo;
        }
    }

    if (faseAtual == 3 && perdeuNoTurno == 0 && voltarMenu == 0) {
        moverBoss();
    }
}


void moverBoss() {
    int dl, dc;
    int novaL, novaC;
    int dist;

    if (bossVida <= 0) {
        return;
    }

    bossTurnos++;

    dist = absoluto(jogadorL - bossL) + absoluto(jogadorC - bossC);
    if (dist <= 1) {
        receberDano("O boss tocou em voce.");
        return;
    }

    
    if (bossTurnos % 2 == 1) {
        strcpy(mensagem, "O boss esta observando e nao se moveu neste turno.");
        return;
    }

    dl = 0;
    dc = 0;

    if (bossTurnos % 4 == 0) {
        if (jogadorC < bossC) dc = -1;
        if (jogadorC > bossC) dc = 1;
    } else {
        if (jogadorL < bossL) dl = -1;
        if (jogadorL > bossL) dl = 1;
    }

    novaL = bossL + dl;
    novaC = bossC + dc;

    if (dl == 0 && dc == 0) {
        strcpy(mensagem, "O boss tentou alinhar o movimento, mas ficou parado.");
        return;
    }

    if (novaL == jogadorL && novaC == jogadorC) {
        receberDano("O boss avancou em voce.");
        return;
    }

    if (podeBossAndar(novaL, novaC) == 1) {
        mapa[bossL][bossC] = ' ';
        bossL = novaL;
        bossC = novaC;
        mapa[bossL][bossC] = 'Z';
        strcpy(mensagem, "O boss se moveu em movimento alternado.");
    } else {
        strcpy(mensagem, "O boss tentou se mover, mas ficou bloqueado.");
    }
}


void receberDano(char motivo[]) {
    vidas--;
    perdeuNoTurno = 1;

    if (vidas <= 0) {
        telaGameOver();
        voltarMenu = 1;
    } else {
        reiniciarFaseAtual();
        sprintf(mensagem, "%s Voce perdeu 1 vida. A fase foi reiniciada.", motivo);
    }
}


