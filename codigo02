char lerTecla() {
#ifdef _WIN32
    return _getch();
#else
    struct termios antigo, novo;
    char tecla;

    tcgetattr(STDIN_FILENO, &antigo);
    novo = antigo;
    novo.c_lflag = novo.c_lflag & ~(ICANON | ECHO);
    tcsetattr(STDIN_FILENO, TCSANOW, &novo);

    tecla = getchar();

    tcsetattr(STDIN_FILENO, TCSANOW, &antigo);
    return tecla;
#endif
}


